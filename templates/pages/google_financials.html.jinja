{% extends "layout.html.jinja" %}

{% block extra_head %}
{% include "partials/_jsonld_breadcrumb.html.jinja" %}
{% endblock %}

{% block content %}
<nav aria-label="breadcrumb" class="text-[10px] text-outline uppercase font-mono mb-6">
  <a href="/" class="hover:text-primary-container">HOME</a>
  <span class="text-outline-variant"> / </span>
  <span class="text-primary-container">GOOGLE FINANCIALS</span>
</nav>

{# ── Header ── #}
<section class="max-w-4xl mx-auto mb-8">
  <p class="text-[10px] text-outline uppercase font-mono mb-3 tracking-widest">&gt; GOOGLE FINANCIALS SEO ANALYZER</p>
  <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3 text-white">Dati finanziari Alphabet &amp; implicazioni SEO</h1>
  <p class="text-sm text-outline font-mono">
    Ultimo aggiornamento: <span class="text-primary-container">{{ updated_label }}</span> &middot;
    Fonte: <a href="https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=0001652044&type=10-Q&dateb=&owner=include&count=5&action=getcompany" class="text-primary-container hover:underline" target="_blank" rel="noopener">SEC EDGAR</a>
  </p>
</section>

{% if latest %}
{# ── KPI Cards — latest quarter ── #}
<section class="max-w-4xl mx-auto mb-12">
  <h2 class="text-xs text-outline uppercase font-mono mb-4 tracking-widest">&gt; Q{{ latest.fiscal_quarter }} {{ latest.fiscal_year }} &mdash; METRICHE CHIAVE</h2>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    {% for key in kpi_keys %}
      {% set m = latest.metrics[key] if key in latest.metrics else none %}
      {% if m %}
      <div class="bg-surface-container-lowest border border-outline-variant p-4">
        <p class="text-[10px] text-outline uppercase font-mono mb-2 tracking-wider">{{ m.label }}</p>
        <p class="text-2xl font-bold text-white">${{ "{:,.0f}".format(m.value_usd_millions) }}M</p>
        {% if m.yoy_change_pct is not none %}
        <p class="text-xs font-mono mt-1 {{ 'text-green-400' if m.yoy_change_pct >= 0 else 'text-red-400' }}">
          YoY {{ "{:+.1f}".format(m.yoy_change_pct) }}%
        </p>
        {% endif %}
      </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if latest.tac_as_pct_of_search_revenue is not none %}
  <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-4">
    <div class="bg-surface-container-lowest border border-outline-variant p-4">
      <p class="text-[10px] text-outline uppercase font-mono mb-2 tracking-wider">TAC % Search Revenue</p>
      <p class="text-xl font-bold text-white">{{ "{:.1f}".format(latest.tac_as_pct_of_search_revenue) }}%</p>
    </div>
    {% if latest.search_as_pct_of_total_revenue is not none %}
    <div class="bg-surface-container-lowest border border-outline-variant p-4">
      <p class="text-[10px] text-outline uppercase font-mono mb-2 tracking-wider">Search % Fatturato</p>
      <p class="text-xl font-bold text-white">{{ "{:.1f}".format(latest.search_as_pct_of_total_revenue) }}%</p>
    </div>
    {% endif %}
    {% if latest.operating_margin_pct is not none %}
    <div class="bg-surface-container-lowest border border-outline-variant p-4">
      <p class="text-[10px] text-outline uppercase font-mono mb-2 tracking-wider">Margine operativo</p>
      <p class="text-xl font-bold text-white">{{ "{:.1f}".format(latest.operating_margin_pct) }}%</p>
    </div>
    {% endif %}
  </div>
  {% endif %}
</section>
{% endif %}

{# ── Revenue trend charts ── #}
{% if snapshots | length > 1 %}
<section class="max-w-4xl mx-auto mb-14">
  <h2 class="text-xs text-outline uppercase font-mono mb-1 tracking-widest">&gt; TREND RICAVI</h2>
  <h3 class="text-xl font-bold text-white mb-4">Ricavi trimestrali per segmento</h3>
  <div id="chart-revenue" class="bg-surface-container-lowest p-4 border border-outline-variant mb-6" style="height: 320px;"></div>

  <h3 class="text-xl font-bold text-white mb-4">TAC come % dei ricavi Search</h3>
  <div id="chart-tac" class="bg-surface-container-lowest p-4 border border-outline-variant mb-6" style="height: 240px;"></div>

  <h3 class="text-xl font-bold text-white mb-4">Investimenti (CapEx) trimestrali</h3>
  <div id="chart-capex" class="bg-surface-container-lowest p-4 border border-outline-variant" style="height: 240px;"></div>
</section>
{% endif %}

{# ── Historical table ── #}
{% if snapshots %}
<section class="max-w-4xl mx-auto mb-14">
  <h2 class="text-xs text-outline uppercase font-mono mb-1 tracking-widest">&gt; STORICO</h2>
  <h3 class="text-xl font-bold text-white mb-4">Tutti i trimestri</h3>

  <div class="overflow-x-auto">
    <table class="w-full text-xs font-mono border-collapse">
      <thead>
        <tr class="text-outline uppercase tracking-wider">
          <th class="text-left py-2 px-2 border-b border-outline-variant">Trimestre</th>
          {% for key in table_keys %}
          <th class="text-right py-2 px-2 border-b border-outline-variant">{{ table_labels[key] }}</th>
          {% endfor %}
          <th class="text-right py-2 px-2 border-b border-outline-variant">TAC%</th>
          <th class="text-right py-2 px-2 border-b border-outline-variant">Margine</th>
        </tr>
      </thead>
      <tbody>
        {% for s in snapshots | reverse %}
        <tr class="border-b border-outline-variant/30 hover:bg-surface-container-low/50">
          <td class="py-2 px-2 text-primary-container">
            <a href="/google-financials/{{ s.fiscal_year }}-Q{{ s.fiscal_quarter }}/" class="hover:underline">
              Q{{ s.fiscal_quarter }} {{ s.fiscal_year }}
            </a>
          </td>
          {% for key in table_keys %}
            {% set m = s.metrics[key] if key in s.metrics else none %}
            <td class="py-2 px-2 text-right text-on-surface-variant">
              {% if m %}${{ "{:,.0f}".format(m.value_usd_millions) }}M{% else %}&mdash;{% endif %}
            </td>
          {% endfor %}
          <td class="py-2 px-2 text-right text-on-surface-variant">
            {% if s.tac_as_pct_of_search_revenue is not none %}{{ "{:.1f}".format(s.tac_as_pct_of_search_revenue) }}%{% else %}&mdash;{% endif %}
          </td>
          <td class="py-2 px-2 text-right text-on-surface-variant">
            {% if s.operating_margin_pct is not none %}{{ "{:.1f}".format(s.operating_margin_pct) }}%{% else %}&mdash;{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endif %}

{# ── Quarterly analysis reports ── #}
{% if analyses %}
<section class="max-w-4xl mx-auto mb-14">
  <h2 class="text-xs text-outline uppercase font-mono mb-1 tracking-widest">&gt; ANALISI TRIMESTRALI</h2>
  <h3 class="text-xl font-bold text-white mb-4">Report editoriali SEO</h3>

  <div class="space-y-4">
    {% for a in analyses | reverse %}
    <a href="/google-financials/{{ a.fiscal_year }}-Q{{ a.fiscal_quarter }}/"
       class="block p-4 bg-surface-container-lowest border border-outline-variant hover:border-primary-container transition-colors">
      <p class="text-[10px] text-outline uppercase font-mono mb-2 tracking-wider">Q{{ a.fiscal_quarter }} {{ a.fiscal_year }}</p>
      <h4 class="text-base font-bold text-white mb-1">{{ a.title_it }}</h4>
      <p class="text-sm text-on-surface-variant">{{ a.subtitle_it }}</p>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ── Inline chart data ── #}
{% if snapshots | length > 1 %}
<script>
const GF_DATA = {{ chart_json | safe }};
</script>
<script>
(function() {
  // Simple inline bar/line chart rendering using canvas
  function drawChart(containerId, data, options) {
    const container = document.getElementById(containerId);
    if (!container || !data || data.length === 0) return;

    const canvas = document.createElement('canvas');
    canvas.width = container.clientWidth;
    canvas.height = parseInt(container.style.height) || 300;
    container.appendChild(canvas);
    const ctx = canvas.getContext('2d');

    const padding = { top: 20, right: 20, bottom: 40, left: 60 };
    const w = canvas.width - padding.left - padding.right;
    const h = canvas.height - padding.top - padding.bottom;

    const series = options.series || ['value'];
    const colors = options.colors || ['#00f63e', '#4dabf7', '#ffa94d', '#ff6b6b'];
    const chartType = options.type || 'line';

    // Find global min/max
    let maxVal = 0;
    data.forEach(d => {
      series.forEach(s => { if (d[s] > maxVal) maxVal = d[s]; });
    });
    maxVal *= 1.1;

    // Draw grid
    ctx.strokeStyle = '#333';
    ctx.lineWidth = 0.5;
    for (let i = 0; i <= 4; i++) {
      const y = padding.top + (h / 4) * i;
      ctx.beginPath();
      ctx.moveTo(padding.left, y);
      ctx.lineTo(padding.left + w, y);
      ctx.stroke();

      ctx.fillStyle = '#888';
      ctx.font = '10px monospace';
      ctx.textAlign = 'right';
      const val = maxVal - (maxVal / 4) * i;
      ctx.fillText('$' + Math.round(val / 1000) + 'B', padding.left - 5, y + 3);
    }

    // Draw labels
    ctx.fillStyle = '#888';
    ctx.font = '9px monospace';
    ctx.textAlign = 'center';
    const step = Math.max(1, Math.floor(data.length / 10));
    data.forEach((d, i) => {
      if (i % step === 0 || i === data.length - 1) {
        const x = padding.left + (w / (data.length - 1)) * i;
        ctx.fillText(d.label, x, canvas.height - 5);
      }
    });

    // Draw series
    series.forEach((s, si) => {
      ctx.strokeStyle = colors[si % colors.length];
      ctx.fillStyle = colors[si % colors.length];
      ctx.lineWidth = 2;

      if (chartType === 'bar') {
        const barW = (w / data.length) * 0.7;
        data.forEach((d, i) => {
          const x = padding.left + (w / data.length) * i + (w / data.length) * 0.15;
          const barH = (d[s] / maxVal) * h;
          ctx.globalAlpha = 0.8;
          ctx.fillRect(x, padding.top + h - barH, barW, barH);
          ctx.globalAlpha = 1;
        });
      } else {
        ctx.beginPath();
        data.forEach((d, i) => {
          const x = padding.left + (w / (data.length - 1)) * i;
          const y = padding.top + h - (d[s] / maxVal) * h;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        });
        ctx.stroke();

        // Draw dots
        data.forEach((d, i) => {
          const x = padding.left + (w / (data.length - 1)) * i;
          const y = padding.top + h - (d[s] / maxVal) * h;
          ctx.beginPath();
          ctx.arc(x, y, 3, 0, Math.PI * 2);
          ctx.fill();
        });
      }
    });

    // Legend
    if (series.length > 1 && options.labels) {
      let lx = padding.left;
      series.forEach((s, si) => {
        ctx.fillStyle = colors[si % colors.length];
        ctx.fillRect(lx, 4, 12, 3);
        ctx.fillStyle = '#ccc';
        ctx.font = '10px monospace';
        ctx.textAlign = 'left';
        ctx.fillText(options.labels[si] || s, lx + 16, 10);
        lx += ctx.measureText(options.labels[si] || s).width + 30;
      });
    }
  }

  if (typeof GF_DATA !== 'undefined') {
    // Revenue chart
    if (GF_DATA.revenue) {
      drawChart('chart-revenue', GF_DATA.revenue, {
        type: 'line',
        series: ['search', 'youtube', 'cloud'],
        colors: ['#00f63e', '#ff6b6b', '#4dabf7'],
        labels: ['Search', 'YouTube', 'Cloud']
      });
    }

    // TAC chart
    if (GF_DATA.tac) {
      drawChart('chart-tac', GF_DATA.tac, {
        type: 'line',
        series: ['tac_pct'],
        colors: ['#ffa94d'],
        labels: ['TAC % Search']
      });
    }

    // CapEx chart
    if (GF_DATA.capex) {
      drawChart('chart-capex', GF_DATA.capex, {
        type: 'bar',
        series: ['capex'],
        colors: ['#4dabf7'],
        labels: ['CapEx']
      });
    }
  }
})();
</script>
{% endif %}

{% endblock %}
