██║   ██║███████╗███████╗█████╗  ██████╔╝██║   ██║███████║   ██║   ██║   ██║██████╔╝██║██║   ██║   ███████╗█████╗  ██║   ██║
██║   ██║╚════██║╚════██║██╔══╝  ██╔══██╗╚██╗ ██╔╝██╔══██║   ██║   ██║   ██║██╔══██╗██║██║   ██║   ╚════██║██╔══╝  ██║   ██║
╚██████╔╝███████║███████║███████╗██║  ██║ ╚████╔╝ ██║  ██║   ██║   ╚██████╔╝██║  ██║██║╚██████╔╝██╗███████║███████╗╚██████╔╝
 ╚═════╝ ╚══════╝╚══════╝╚══════╝╚═╝  ╚═╝  ╚═══╝  ╚═╝  ╚═╝   ╚═╝    ╚═════╝ ╚═╝  ╚═╝╚═╝ ╚═════╝ ╚═╝╚══════╝╚══════╝ ╚═════╝
  </pre>
  <div class="md:hidden text-primary-container font-bold text-2xl tracking-tight uppercase terminal-glow mb-4">OSSERVATORIO SEO</div>
  <div class="flex items-center gap-2 text-outline">
    <span class="text-primary-container">●</span>
    <span class="text-[10px] tracking-widest uppercase break-words" id="meta">{{ meta_line }}</span>
  </div>
</section>

<section class="mb-16" id="top10-section">
  <div class="flex items-center gap-4 mb-8">
    <h2 class="text-2xl font-bold tracking-tight uppercase" id="top10-title">{{ top10_title | default("> TOP 10 DEL GIORNO") }}</h2>
    <div class="flex-grow h-px bg-outline-variant border-dashed border-t"></div>
  </div>
  <div id="top10" class="grid grid-cols-1 gap-px bg-outline-variant border border-outline-variant">
  {% for card in top10_cards %}
  {{ card | safe }}
  {% endfor %}
  </div>
</section>

{% if tracker_teaser and tracker_teaser.ai_top3 %}
<section class="mb-12 max-w-4xl" id="tracker-teaser">
  <div class="flex items-center gap-4 mb-4">
    <h2 class="text-lg font-bold tracking-tight uppercase text-white">&gt; AI TRACKER &mdash; ADOZIONE E TENDENZE</h2>
    <div class="flex-grow h-px bg-outline-variant border-dashed border-t"></div>
    <a href="/tracker/" class="text-xs text-primary-container hover:underline uppercase font-mono tracking-wider">VEDI TUTTO &rarr;</a>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    {% for d in tracker_teaser.ai_top3 %}
    <div class="p-4 border border-outline-variant bg-surface-container-lowest text-center">
      <p class="text-2xl font-bold text-primary-container font-mono">{{ d.avg }}</p>
      <p class="text-xs text-white mt-1">{{ d.name }}</p>
      <p class="text-[10px] text-outline uppercase tracking-wider mt-0.5">#{{ loop.index }} in Italia</p>
    </div>
    {% endfor %}
    {% if tracker_teaser.bot_pct_it is not none %}
    <div class="p-4 border border-outline-variant bg-surface-container-lowest text-center">
      <p class="text-2xl font-bold text-primary-container font-mono">{{ '{:.1f}'.format(tracker_teaser.bot_pct_it) }}%</p>
      <p class="text-xs text-white mt-1">Traffico bot</p>
      <p class="text-[10px] text-outline uppercase tracking-wider mt-0.5">Italia</p>
    </div>
    {% endif %}
  </div>
  <p class="text-[10px] text-outline mt-2">Interesse di ricerca relativo (Google Trends, 0-100) &mdash; settimana {{ tracker_teaser.year }}-W{{ '%02d'|format(tracker_teaser.week) }}</p>
</section>
{% endif %}

{% if financials_teaser and financials_teaser.search_revenue %}
<section class="mb-12 max-w-4xl" id="financials-teaser">
  <div class="flex items-center gap-4 mb-4">
    <h2 class="text-lg font-bold tracking-tight uppercase text-white">&gt; GOOGLE FINANCIALS &mdash; IMPLICAZIONI SEO</h2>
    <div class="flex-grow h-px bg-outline-variant border-dashed border-t"></div>
    <a href="/google-financials/" class="text-xs text-primary-container hover:underline uppercase font-mono tracking-wider">VEDI TUTTO &rarr;</a>
  </div>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <div class="p-4 border border-outline-variant bg-surface-container-lowest text-center">
      <p class="text-2xl font-bold text-primary-container font-mono">${{ '{:,.0f}'.format(financials_teaser.search_revenue) }}M</p>
      <p class="text-xs text-white mt-1">Search Revenue</p>
      {% if financials_teaser.search_yoy is not none %}
      <p class="text-[10px] {{ 'text-green-400' if financials_teaser.search_yoy >= 0 else 'text-red-400' }} uppercase tracking-wider mt-0.5">YoY {{ '{:+.1f}'.format(financials_teaser.search_yoy) }}%</p>
      {% endif %}
    </div>
    {% if financials_teaser.cloud_revenue %}
    <div class="p-4 border border-outline-variant bg-surface-container-lowest text-center">
      <p class="text-2xl font-bold text-primary-container font-mono">${{ '{:,.0f}'.format(financials_teaser.cloud_revenue) }}M</p>
      <p class="text-xs text-white mt-1">Cloud Revenue</p>
      <p class="text-[10px] text-outline uppercase tracking-wider mt-0.5">AI infrastructure</p>
    </div>
    {% endif %}
    {% if financials_teaser.capex %}
    <div class="p-4 border border-outline-variant bg-surface-container-lowest text-center">
      <p class="text-2xl font-bold text-primary-container font-mono">${{ '{:,.0f}'.format(financials_teaser.capex) }}M</p>
      <p class="text-xs text-white mt-1">CapEx</p>
      <p class="text-[10px] text-outline uppercase tracking-wider mt-0.5">AI investment</p>
    </div>
    {% endif %}
  </div>
  <p class="text-[10px] text-outline mt-2">Dati SEC EDGAR &mdash; {{ financials_teaser.quarter }}</p>
</section>
{% endif %}

<section class="mb-12" id="categories-section">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-2xl font-bold tracking-tight uppercase" id="categories-title">{{ categories_title | default("> TUTTE PER CATEGORIA") }}</h2>
    <div class="flex-grow h-px bg-outline-variant border-dashed border-t"></div>
  </div>
  <div id="categories" class="flex flex-col gap-6">
  {% for cat in categories %}
    <details class="cat-accordion group">
      <summary class="flex items-center justify-between border-b border-primary-container pb-2 cursor-pointer list-none hover:bg-surface-container-lowest transition-colors">
        <h3 class="text-primary-container font-bold uppercase tracking-widest text-sm flex items-center gap-3">
          <span class="cat-marker text-primary-container font-mono shrink-0 w-4 inline-block text-center"></span>
          [ <a href="{{ cat.path }}" class="hover:underline" onclick="event.stopPropagation()">{{ cat.label }}</a> ]
          <span class="text-outline text-[10px] font-normal normal-case tracking-normal">({{ cat.cards | length }})</span>
        </h3>
        <span class="material-symbols-outlined text-primary-container text-sm">{{ cat.icon }}</span>
      </summary>
      <div class="flex flex-col gap-4 pt-6">
      {% for card in cat.cards %}
      {{ card | safe }}
      {% endfor %}
      </div>
    </details>
  {% endfor %}
  </div>
</section>

{% if failed_sources %}
<section class="mb-12" id="failed">
  <div class="flex items-center gap-4 mb-6">
    <h2 class="text-lg font-bold tracking-tight uppercase text-error">&gt; FONTI CON ERRORI</h2>
    <div class="flex-grow h-px bg-outline-variant border-dashed border-t"></div>
  </div>
  <ul id="failed-list" class="flex flex-col gap-2 font-mono text-xs text-on-surface-variant">
  {% for fs in failed_sources %}
  <li class="border-l-2 border-error px-3 py-2 bg-surface-container-lowest">
    <span class="text-error uppercase">[ERR]</span>
    <code class="text-white">{{ fs.id }}</code>:
    <span class="text-on-surface-variant">{{ fs.error }}</span>
  </li>
  {% endfor %}
  </ul>
</section>
{% endif %}

<section class="mb-12" id="archive-results" hidden>
  <div class="flex items-center gap-4 mb-6">
    <h2 class="text-2xl font-bold tracking-tight uppercase">&gt; RISULTATI DALL'ARCHIVIO</h2>
    <div class="flex-grow h-px bg-outline-variant border-dashed border-t"></div>
  </div>
  <p class="text-[10px] text-outline uppercase font-mono mb-4" id="archive-results-meta"></p>
  <div id="archive-results-list" class="flex flex-col gap-10"></div>
</section>
{% endblock %}
